# Auto detect text files and normalize line endings
* text=auto

# Shell scripts must use LF (they run on Linux/Pi)
*.sh text eol=lf
setup.sh text eol=lf

# Python files
*.py text eol=lf

# Config files
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Keep Windows line endings for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
